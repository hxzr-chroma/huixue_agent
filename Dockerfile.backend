FROM python:3.10-slim

WORKDIR /app

# 复制依赖文件
COPY requirements.txt .

# 安装依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY . .

# 暴露端口
EXPOSE 8000

# 复制启动脚本
COPY start_backend.sh /app/start_backend.sh
RUN chmod +x /app/start_backend.sh

# 启动FastAPI后端
CMD ["/app/start_backend.sh"]
